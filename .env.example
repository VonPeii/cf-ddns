# =============================================
# CF-DDNS 凭据配置
# 复制为 .env 后填入真实值：cp .env.example .env
# =============================================

# === 域名 #1 ===
DOMAIN_1_NAME=blog.example.com
DOMAIN_1_ZONE_ID=your_zone_id_here
DOMAIN_1_TOKEN=your_api_token_here

# === 域名 #2 ===
DOMAIN_2_NAME=cdn.example.net
DOMAIN_2_ZONE_ID=your_zone_id_here
DOMAIN_2_TOKEN=your_api_token_here

# === 域名 #3 ===
DOMAIN_3_NAME=img.example.org
DOMAIN_3_ZONE_ID=your_zone_id_here
DOMAIN_3_TOKEN=your_api_token_here

# 添加更多域名只需追加：
# DOMAIN_4_NAME=...
# DOMAIN_4_ZONE_ID=...
# DOMAIN_4_TOKEN=...
